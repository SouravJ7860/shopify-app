{% assign announcement = shop.metafields.my_app.announcement.value %}

{% if announcement != blank %}

<div id="announcement-banner" class="announcement-banner">

  <div class="announcement-left">
    📢
  </div>

  <div class="announcement-center">
    <span class="sale-text">
      🔥 {{ announcement }} 🔥
    </span>
  </div>

  <div class="announcement-right">
    <a href="/collections/all" class="shop-now-btn">
      Shop Now →
    </a>
  </div>

  <button
    class="announcement-close"
    onclick="document.getElementById('announcement-banner').style.display='none'"
  >
    ✕
  </button>

</div>

<style>

.announcement-banner {
  position: sticky;
  top: 0;
  z-index: 99999;

  display: flex;
  align-items: center;
  justify-content: center;

  gap: 20px;

  width: 100%;

  padding: 14px 60px;

  background: linear-gradient(
    90deg,
    #1d4ed8,
    #7c3aed,
    #db2777,
    #f97316
  );

  color: white;

  box-shadow:
    0 8px 20px rgba(0,0,0,0.15);

  overflow: hidden;
}

.announcement-banner::before {
  content: "";

  position: absolute;

  top: 0;
  left: -100%;

  width: 100%;
  height: 100%;

  background: linear-gradient(
    90deg,
    transparent,
    rgba(255,255,255,0.25),
    transparent
  );

  animation: shine 4s infinite;
}

@keyframes shine {
  100% {
    left: 100%;
  }
}

.announcement-left {
  font-size: 24px;
}

.announcement-center {
  flex: 1;
  text-align: center;
}

.sale-text {
  font-size: 18px;
  font-weight: 800;
  letter-spacing: 0.5px;
  text-transform: uppercase;

  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% {
    transform: scale(1);
  }

  50% {
    transform: scale(1.05);
  }

  100% {
    transform: scale(1);
  }
}

.shop-now-btn {
  background: white;
  color: #7c3aed !important;

  text-decoration: none;

  padding: 10px 20px;

  border-radius: 999px;

  font-weight: 700;

  transition: all .3s ease;
}

.shop-now-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 15px rgba(0,0,0,.2);
}

.announcement-close {
  position: absolute;

  right: 15px;
  top: 50%;

  transform: translateY(-50%);

  border: none;
  background: transparent;

  color: white;

  font-size: 22px;

  cursor: pointer;
}

.announcement-close:hover {
  opacity: .8;
}

@media screen and (max-width: 768px) {

  .announcement-banner {
    padding: 12px 40px 12px 12px;
  }

  .announcement-left,
  .announcement-right {
    display: none;
  }

  .sale-text {
    font-size: 14px;
  }
}

</style>

{% endif %}

{% schema %}
{
  "name": "Announcement Banner",
  "target": "body",
  "settings": []
}
{% endschema %}